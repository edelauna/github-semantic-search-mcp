{
  "name": "github-semantic-search-mcp",
  "version": "1.0.4",
  "description": "",
  "engines": {
    "vscode": "^1.101.0"
  },
  "icon": "gss-ai-logo-ico.png",
  "publisher": "edelauna",
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "language-model-tools",
    "chat-participant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edelauna/github-semantic-search-mcp.git",
    "directory": "vscode-extension"
  },
  "main": "./out/extension.js",
  "activationEvents": [],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "github-semantic-search-server",
        "label": "This MCP server provides semantic code search capabilities by indexing GitHub repositories and serving queries via a remote MCP interface. It is designed to facilitate retrieval-augmented generation (RAG) queries."
      }
    ]
  },
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  }
}
